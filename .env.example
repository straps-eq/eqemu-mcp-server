# ---------------------------------------------------------------------------
# EQEmu MCP Server Configuration
# ---------------------------------------------------------------------------
# Copy to .env and fill in your values.
# On akk-stack deployments, run `make info` at /opt/akk-stack/ to find
# your passwords and IP.

# ---------- Permission mode ----------
# "read"      — default, only exposes read-only tools (safe for public use)
# "readwrite" — enables ALL tools including database writes, quest editing,
#               spawn/NPC/loot creation, etc.
EQEMU_ACCESS_MODE=read

# ---------- Paths ----------
# Where the EQEmu source code lives (C++ codebase)
EQEMU_SOURCE_PATH=/opt/akk-stack/code

# Where quest scripts live
EQEMU_QUESTS_PATH=/opt/akk-stack/server/quests

# Server root (plugins, lua_modules, logs, eqemu_config.json, etc.)
EQEMU_SERVER_PATH=/opt/akk-stack/server

# ---------- Database ----------
# For akk-stack: the host's external IP (not 127.0.0.1) since the MCP
# server runs outside the Docker network.
EQEMU_DB_HOST=127.0.0.1
EQEMU_DB_PORT=3306
EQEMU_DB_USER=eqemu
EQEMU_DB_PASSWORD=your_db_password_here
EQEMU_DB_NAME=peq

# ---------- Authentication ----------
# Set a token to require authentication on SSE connections.
# Leave empty or commented out for no authentication.
# Clients connect with: http://YOUR_IP:8888/sse?token=YOUR_TOKEN
# EQEMU_MCP_TOKEN=your_secret_token_here

# ---------- Tools ----------
# Path to ripgrep binary (optional — falls back to 'rg' in PATH)
# RG_PATH=/usr/bin/rg

# ---------- Documentation ----------
# Path to a local clone of https://github.com/EQEmu/eqemu-docs-v2
# If not set, the server will try common locations or auto-clone on first use.
# EQEMU_DOCS_PATH=/opt/akk-stack/eqemu-docs

# ---------- Docker containers (optional, for future server control) ----------
EQEMU_DOCKER_CONTAINER=akk-stack-eqemu-server-1
EQEMU_MARIADB_CONTAINER=akk-stack-mariadb-1
